# =================================================================
# Patient Registration System - Environment Configuration Template
# Copie para .env e preencha conforme o seu ambiente.
# Este arquivo usa apenas placeholders; nada aqui habilita integrações por si só.
# =================================================================

# Flask / sessão
# Deixe em branco para desenvolvimento local; em produção, defina uma chave forte.
SECRET_KEY=
FLASK_ENV=production
FLASK_DEBUG=0
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
SESSION_IDLE_TIMEOUT_MINUTES=30

# Servidor
SERVER_HOST=127.0.0.1
SERVER_PORT=5000
DESKTOP_MODE=false

# Google Calendar (opcional; também pode ser configurado por especialidade na UI)
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_TZ=America/Fortaleza
GOOGLE_CALENDAR_ICS_URL=
ORTOPEDIA_AGENDA_URL=
CALENDAR_CACHE_TTL_SECONDS=60
CALENDAR_CACHE_TTL_MINUTES=5

# Google Forms (opcional; deixe em branco até configurar)
GOOGLE_FORMS_EDIT_ID=
GOOGLE_FORMS_PUBLIC_ID=
GOOGLE_FORMS_VIEWFORM_URL=
GOOGLE_FORMS_TIMEOUT=10

# Bootstrap do primeiro administrador
# Obrigatório apenas na primeira subida sem admins cadastrados.
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_FULL_NAME=Administrador do Sistema
ADMIN_BOOTSTRAP_SPECIALTY=ortopedia

# Hardening de respostas HTTP
SECURITY_HEADERS_ENABLED=true
SECURITY_CSP_REPORT_ONLY=true
SECURITY_CSP_REPORT_URI=
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE_SECONDS=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=false

# Banco / manutenção
# SQLALCHEMY_DATABASE_URI=sqlite:///instance/prontuario.db
AUTO_MIGRATE=false

# Lifecycle (modo desktop)
LIFECYCLE_TIMEOUT_SECONDS=30
LIFECYCLE_HEARTBEAT_SECONDS=5
